# Production landing

galliard.by, www.galliard.by {
  encode zstd gzip
  reverse_proxy landing:3000 {
    lb_policy least_conn
    health_uri /api/healthz
    health_interval 5s
    health_timeout 2s
    fail_duration 10s
  }

  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Content-Type-Options "nosniff"
    X-Frame-Options "SAMEORIGIN"
    Referrer-Policy "strict-origin-when-cross-origin"
  }
}

# Production admin
admin.galliard.by {
  encode zstd gzip
  reverse_proxy admin-crm:3001 {
    lb_policy least_conn
    health_uri /api/healthz
    health_interval 5s
    health_timeout 2s
    fail_duration 10s
  }

  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Content-Type-Options "nosniff"
    X-Frame-Options "SAMEORIGIN"
    Referrer-Policy "strict-origin-when-cross-origin"
  }
}

# Mailcow web entrypoints (UI, autodiscover, autoconfig)
# Caddy runs in container, so for host-bound Mailcow nginx use host gateway.
# Use Mailcow HTTPS upstream (8443), otherwise HTTP upstream (8080) may cause redirect loops.
# and set in docker-compose for caddy:
# extra_hosts:
#   - "host.docker.internal:host-gateway"
# Mailcow recommended:
# HTTP_BIND=127.0.0.1
# HTTP_PORT=8080
# HTTPS_BIND=127.0.0.1
# HTTPS_PORT=8443
# SKIP_LETS_ENCRYPT=y
mail.galliard.by {
  encode zstd gzip
  reverse_proxy https://host.docker.internal:8443 {
    transport http {
      tls_insecure_skip_verify
      tls_server_name mail.galliard.by
    }
    header_up Host mail.galliard.by
    header_up X-Forwarded-Proto https
    header_up X-Forwarded-Host {host}
  }

  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Content-Type-Options "nosniff"
    X-Frame-Options "SAMEORIGIN"
    Referrer-Policy "strict-origin-when-cross-origin"
  }
}

autodiscover.galliard.by, autoconfig.galliard.by {
  encode zstd gzip
  reverse_proxy https://host.docker.internal:8443 {
    transport http {
      tls_insecure_skip_verify
      tls_server_name mail.galliard.by
    }
    header_up Host {host}
    header_up X-Forwarded-Proto https
    header_up X-Forwarded-Host {host}
  }

  header {
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    X-Content-Type-Options "nosniff"
    X-Frame-Options "SAMEORIGIN"
    Referrer-Policy "strict-origin-when-cross-origin"
  }
}

# Local quick access: landing
:8088 {
  encode zstd gzip
  reverse_proxy landing:3000 {
    lb_policy least_conn
    health_uri /api/healthz
    health_interval 5s
    health_timeout 2s
    fail_duration 10s
  }
}

